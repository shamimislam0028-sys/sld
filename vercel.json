{
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/parse-docx",
      "destination": "/api/parse-docx.js"
    },
    {
      "source": "/api/generate",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/health",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
